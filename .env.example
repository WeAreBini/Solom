# Database URL for Prisma
# Using a placeholder for generation - will be set properly at runtime
DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/placeholder?pgbouncer=true&connect_timeout=15"

# Solom Data Service URL
# This is the Python/FastAPI service that fetches market data from Yahoo Finance
NEXT_PUBLIC_SOLOM_DATA_SERVICE_URL=https://solom-data-service.up.railway.app

# For local development:
# NEXT_PUBLIC_SOLOM_DATA_SERVICE_URL=http://localhost:8080

# WebSocket URL for real-time price streaming (optional)
NEXT_PUBLIC_WS_URL=

# Note: FMP_API_KEY is no longer needed.
# We now use Yahoo Finance via solom-data-service (no API key required).